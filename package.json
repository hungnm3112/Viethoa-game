{
  "name": "viethoa-state-of-decay-yose",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --config nodemon.json",
    "extract": "node tools/extract.js",
    "extract:runtime": "node tools/extract.js --include-btxt",
    "scan": "node tools/scan.js",
    "build-jobs": "node tools/build-jobs.js",
    "build-jobs:phase1": "node tools/build-jobs.js --profile=phase1",
    "build-jobs:phase2": "node tools/build-jobs.js --profile=phase2",
    "build-jobs:phase3": "node tools/build-jobs.js --profile=phase3",
    "build-jobs:base": "node tools/build-jobs.js --profile=base-game",
    "build-jobs:breakdown-core": "node tools/build-jobs.js --profile=breakdown-core",
    "build-jobs:breakdown-all": "node tools/build-jobs.js --profile=breakdown-all",
    "build-jobs:lifeline-core": "node tools/build-jobs.js --profile=lifeline-core",
    "build-jobs:lifeline-all": "node tools/build-jobs.js --profile=lifeline-all",
    "build-jobs:level-missions": "node tools/build-jobs.js --profile=level-missions",
    "build-jobs:dlc-core": "node tools/build-jobs.js --profile=breakdown-core,lifeline-core,level-missions",
    "build-jobs:all": "node tools/build-jobs.js",
    "translate": "node --env-file=.env tools/translate.js",
    "translate:phase1": "node --env-file=.env tools/run-translation-pipeline.js --profile=phase1 --limit=8",
    "translate:phase2": "node --env-file=.env tools/run-translation-pipeline.js --profile=phase2 --limit=8",
    "translate:phase3": "node --env-file=.env tools/run-translation-pipeline.js --profile=phase3 --limit=8",
    "translate:base": "node --env-file=.env tools/run-translation-pipeline.js --profile=base-game --limit=8",
    "translate:breakdown-core": "node --env-file=.env tools/run-translation-pipeline.js --profile=breakdown-core --limit=8",
    "translate:breakdown-all": "node --env-file=.env tools/run-translation-pipeline.js --profile=breakdown-all --limit=8",
    "translate:lifeline-core": "node --env-file=.env tools/run-translation-pipeline.js --profile=lifeline-core --limit=8",
    "translate:lifeline-all": "node --env-file=.env tools/run-translation-pipeline.js --profile=lifeline-all --limit=8",
    "translate:level-missions": "node --env-file=.env tools/run-translation-pipeline.js --profile=level-missions --limit=8",
    "translate:dlc-core": "node --env-file=.env tools/run-translation-pipeline.js --profile=breakdown-core,lifeline-core,level-missions --limit=8",
    "translate:all": "node tools/run-translation-pipeline.js --profile=all --limit=8",
    "translate:resume": "node --env-file=.env tools/run-translation-pipeline.js --profile=all --limit=8 --rebuild=false",
    "translation-status": "node tools/translation-status.js",
    "translation-status:phase1": "node tools/translation-status.js --profile=phase1",
    "translation-status:phase2": "node tools/translation-status.js --profile=phase2",
    "translation-status:phase3": "node tools/translation-status.js --profile=phase3",
    "translation-status:base": "node tools/translation-status.js --profile=base-game",
    "translation-status:breakdown-core": "node tools/translation-status.js --profile=breakdown-core",
    "translation-status:breakdown-all": "node tools/translation-status.js --profile=breakdown-all",
    "translation-status:lifeline-core": "node tools/translation-status.js --profile=lifeline-core",
    "translation-status:lifeline-all": "node tools/translation-status.js --profile=lifeline-all",
    "translation-status:level-missions": "node tools/translation-status.js --profile=level-missions",
    "translation-status:dlc-core": "node tools/translation-status.js --profile=breakdown-core,lifeline-core,level-missions",
    "dashboard:generate": "node tools/generate-translation-dashboard.js",
    "dashboard:serve": "node --env-file=.env tools/serve-dashboard.js",
    "rollback:output": "node tools/rollback-output.js",
    "build-btxt": "node tools/build-btxt.js",
    "build-bmd": "node tools/build-bmd.js",
    "build-runtime": "node tools/build-btxt.js",
    "build-basic-embeddedstrings": "node tools/patch-basic-embeddedstrings.js",
    "extract-original-btxt": "node tools/extract-original-btxt.js",
    "build-pak": "node tools/build-pak.js --exclude=.win.bmd,scripts/,libs/",
    "build-pak:full-unsafe": "node tools/build-pak.js",
    "build-game": "node tools/build-btxt.js && node tools/build-pak.js --exclude=.win.bmd,scripts/,libs/",
    "build-btxt:expanded-pilot": "node tools/build-btxt-expanded.js --manifest=config/btxt-expanded-pilot.json",
    "build-btxt:expanded-pilot:dry": "node tools/build-btxt-expanded.js --manifest=config/btxt-expanded-pilot.json --dry-run",
    "build-btxt:expanded-pilot:workflow": "node tools/run-btxt-expanded-workflow.js --manifest=config/btxt-expanded-pilot.json",
    "deploy-btxt:expanded-pilot": "node tools/run-btxt-expanded-workflow.js --manifest=config/btxt-expanded-pilot.json --sync",
    "analyze-dmp": "node tools/analyze-dmp.js",
    "build-font-swf": "node tools/build-font-swf.js",
    "build-ui-aliases": "node tools/build-ui-aliases.js",
    "font-audit": "node tools/font-audit.js",
    "patch-cluster-a": "node tools/patch-cluster-a-fonts.js",
    "patch-cluster-b": "node tools/patch-cluster-b-fonts.js",
    "patch-cluster-c": "node tools/patch-cluster-c-fonts.js",
    "sync-game": "powershell -ExecutionPolicy Bypass -File scripts/sync-output-to-game.ps1",
    "sync-loose-languages": "powershell -ExecutionPolicy Bypass -File scripts/sync-loose-languages-to-game.ps1",
    "sync-btxt-languages": "powershell -ExecutionPolicy Bypass -File scripts/sync-btxt-languages-to-game.ps1",
    "test-menu": "node tools/patch-test-menu.js",
    "test-btxt": "node tools/patch-test-btxt.js",
    "test-font": "node tools/patch-test-font.js",
    "test-gfx-font": "node tools/patch-test-gfx-font.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "mongodb": "^7.3.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
